{
  "name": "codeaira-copilot",
  "displayName": "Codeaira Copilot",
  "publisher": "codeaira",
  "description": "Codeaira API Agentic Copilot",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeaira-copilot.askAgent",
        "title": "Codeaira: Ask Agent"
      },
      {
        "command": "codeaira-copilot.storeToken",
        "title": "Codeaira: Store API Token"
      },
      {
        "command": "codeaira-copilot.checkToken",
        "title": "Codeaira: Check Token Status"
      },
      {
        "command": "codeaira-copilot.inlineGenerate",
        "title": "Codeaira: Inline Code Generate"
      },
      {
        "command": "codeaira-copilot.focusChat",
        "title": "Codeaira: Focus Chat",
        "icon": "$(comment-discussion)"
      }
    ],
    "keybindings": [
      {
        "command": "codeaira-copilot.inlineGenerate",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeaira-copilot.focusChat",
          "group": "navigation@1",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeaira-sidebar",
          "title": "Codeaira",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "codeaira-sidebar": [
        {
          "type": "webview",
          "id": "codeaira.chatView",
          "name": "Codeaira Chat"
        }
      ]
    },
    "configuration": {
      "title": "Codeaira Copilot",
      "properties": {
        "codeaira.modelName": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "The model name to use for completions."
        },
        "codeaira.baseUrl": {
          "type": "string",
          "default": "https://codeaira.qdatalabs.com/api",
          "description": "The base URL for the Codeaira API."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "automation-test": "jest src/test/automation.test.ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "fast-check": "^4.5.3",
    "glob": "^8.1.0",
    "jest": "^30.2.0",
    "mocha": "^10.2.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3"
  }
}
